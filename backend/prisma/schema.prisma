generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  member
}

enum TaskStatus {
  todo
  in_progress
  review
  completed
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum AttendanceStatus {
  present
  absent
  partial
}

enum OrgRole {
  owner
  admin
  member
}

model Organization {
  id          String          @id @default(uuid())
  name        String
  ownerId     String
  createdAt   DateTime        @default(now())
  memberships OrgMembership[]
  workspaces  Workspace[]

  @@map("organization")
}

model OrgMembership {
  id     String       @id @default(uuid())
  userId String
  orgId  String
  role   OrgRole      @default(member)
  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@map("org_membership")
}

model Workspace {
  id          String                @id @default(uuid())
  name        String
  orgId       String
  createdAt   DateTime              @default(now())
  org         Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  memberships WorkspaceMembership[]
  members     Member[]

  @@map("workspaces")
}

model WorkspaceMembership {
  id          String    @id @default(uuid())
  userId      String
  workspaceId String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  canEdit     Boolean   @default(true)
  canView     Boolean   @default(true)
  canDelete   Boolean   @default(true)

  @@unique([userId, workspaceId])
  @@map("workspace_memberships")
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  password         String
  name             String
  role             UserRole  @default(member)
  isPasswordReset  Boolean   @default(false)
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  members              Member[]
  createdMembers       Member[]              @relation("CreatedMembers")
  orgMemberships       OrgMembership[]
  workspaceMemberships WorkspaceMembership[]

  @@map("users")
}

model Member {
  id          String            @id @default(uuid())
  role        String
  email       String
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
  createdById String?
  createdBy   User?             @relation("CreatedMembers", fields: [createdById], references: [id])
  workspaceId String
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks       Task[]
  attendance  DailyAttendance[]

  @@unique([userId, workspaceId])
  @@map("members")
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String
  status      TaskStatus   @default(todo)
  priority    TaskPriority @default(medium)
  dueDate     DateTime
  memberId    String
  member      Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())
  completedAt DateTime?

  @@map("tasks")
}

model DailyAttendance {
  id                  String           @id @default(uuid())
  memberId            String
  member              Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  date                DateTime         @db.Date
  status              AttendanceStatus @default(absent)
  taskSubmittedAt     DateTime?
  allTasksCompletedAt DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  @@unique([memberId, date])
  @@map("daily_attendance")
}
